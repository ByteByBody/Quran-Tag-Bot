# ============================================================
# Quran Tracker Bot — Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# ------------------------------------------------------------------
# REQUIRED
# ------------------------------------------------------------------
# Telegram Bot Token from @BotFather
BOT_TOKEN=your_bot_token_here

# ------------------------------------------------------------------
# TIMEZONE & SCHEDULING
# ------------------------------------------------------------------
# Any valid pytz timezone string, e.g. Asia/Riyadh, Africa/Cairo
TIMEZONE=Africa/Cairo

# Time to send the daily Quran reminder (24-hour HH:MM)
DEFAULT_POST_TIME=08:00

# Time to send the daily completion report (24-hour HH:MM)
REPORT_TIME=22:00

# Time to run automatic database backup (24-hour HH:MM)
BACKUP_TIME=03:00

# ------------------------------------------------------------------
# SECURITY
# ------------------------------------------------------------------
# Comma-separated list of Telegram User IDs for global bot admins
BOT_ADMINS=123456789,987654321

# ------------------------------------------------------------------
# DATABASE
# ------------------------------------------------------------------
DATABASE_PATH=data/quran_tracker.db

# ------------------------------------------------------------------
# LOGGING
# ------------------------------------------------------------------
# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Max size per log file in MB before rotation
LOG_MAX_MB=5

# Number of backup log files to keep
LOG_BACKUP_COUNT=5

# ------------------------------------------------------------------
# OPTIONAL CONTENT (daily post extras)
# ------------------------------------------------------------------
# Include a random Quran verse in the daily post? (true/false)
INCLUDE_DAILY_VERSE=true

# Include a hadith about the Quran in the daily post? (true/false)
INCLUDE_DAILY_HADITH=false

# Include a daily dua in the daily post? (true/false)
INCLUDE_DAILY_DUA=false

# Aliases used by the new feature-flag system (same effect as above)
ENABLE_RANDOM_VERSES=true
ENABLE_RANDOM_HADITH=false
ENABLE_RANDOM_DUA=false

# ------------------------------------------------------------------
# FEATURE FLAGS
# ------------------------------------------------------------------
# Send a weekly summary report? (true/false)
ENABLE_WEEKLY_REPORT=true

# Day of week the weekly report is sent: 0=Mon 1=Tue 2=Wed 3=Thu 4=Fri 5=Sat 6=Sun
WEEKLY_REPORT_DAY=4

# Enable personal badges and achievement notifications? (true/false)
ENABLE_BADGES=true

# Announce badge earnings in the group (as well as privately)? (true/false)
ANNOUNCE_BADGES=true

# Enable group milestone announcements (100/500/1000 check-ins, khatmahs)? (true/false)
ENABLE_MILESTONES=true

# Send private reminders to members who haven't checked in? (true/false)
ENABLE_REMINDERS=false

# Comma-separated list of reminder times in HH:MM (24-hour, group timezone)
# Example: REMINDER_TIMES=20:00,21:30
REMINDER_TIMES=20:00

# ------------------------------------------------------------------
# BACKUPS
# ------------------------------------------------------------------
# Directory to store automatic backups
BACKUP_DIR=data/backups

# Number of automatic backups to retain
BACKUP_RETAIN=7

# ------------------------------------------------------------------
# BOT META
# ------------------------------------------------------------------
BOT_VERSION=2.0.0
